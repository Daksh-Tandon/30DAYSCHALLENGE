class Solution {
    public int maxArea(int[] arr) {
        int n=arr.length;
        int left=0;
        int right=n-1;
        int amount=0,max=Integer.MIN_VALUE;
        while(left!=right){
            amount=Math.min(arr[left],arr[right])*(right-left);
            max=Math.max(amount,max);
            if(arr[left]>arr[right]) right--;
            else left++;

        }
        return max;
        
        
    }
}
