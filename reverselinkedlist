class Solution {
    public int size(ListNode head){
        if(head==null) return 0;
        return 1+size(head.next);
    }
    public ListNode reverse(ListNode head,int i,int k){
        if( i==k) return head;
        ListNode a=head.next;
        ListNode nh=reverse(a,i+1,k);
        a.next=head;
        head.next=null;
        return nh;

       
    }
    public ListNode k1node(ListNode head,int k){
        int c=1;
        ListNode temp=head;
        while(temp!=null && c!=k){
            temp=temp.next;
            c++;

        }
        return temp;
    }
    public ListNode reverseKGroup(ListNode head, int k) {
        int n=size(head);
        if(n<k) return head;
        ListNode h=null;
        ListNode nh=null;
        ListNode temp=head;
        int t1=n/k;
        ListNode prev=null;
        for(int i=0;i<t1;i++){
             ListNode t3=k1node(head,k+1);
             if(h==null) h=reverse(head,1,k);
             else prev.next=reverse(head,1,k);
              prev=head;
             head.next=t3;
             head=t3;
            
             
        }
        return h;
        
          


        
    }
