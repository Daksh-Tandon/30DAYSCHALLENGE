class Solution {
    public int reverse(int n){
        int rev=0;
        while(n!=0){
            int rem=n%10;
            rev=rev*10+rem;
            n=n/10;

        }
        return rev;
    }
    public int mirrorDistance(int n) {
        int revn=reverse(n);
        return Math.abs(revn-n);
        
    }
}
