class Solution {
    public int maxDistance(int[] nums1, int[] nums2) {
        int n=nums1.length,m=nums2.length;
        int i=0,j=0;
        int maxans=0;
        while(i<n && j<m){
            if(nums1[i]<=nums2[j]){
                maxans=Math.max(maxans,j-i);
                j++;
            }
            else{
                if(j<i) j=i;
                i++;
            }
        }
        return maxans;
        
    }
}
