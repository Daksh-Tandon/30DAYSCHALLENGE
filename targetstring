    public int closestTarget(String[] words, String target, int startIndex) {
        int n=words.length;
        int minans=Integer.MAX_VALUE;
        if(words[startIndex].equals(target)) return 0;
        int count=1;
        int st1=startIndex,st=st1;
        for(int i=0;i<n;i++){
            int fidx=(st1+1)%n;
            int bidx=(st-1+n)%n;
            if(words[fidx].equals(target)){
             
                minans=Math.min(minans,count);

            }
            if(words[bidx].equals(target)){
               
                 minans=Math.min(minans,count);

            }
            st=bidx;
            st1=fidx;
            count++;
    

        }
       if(minans==Integer.MAX_VALUE) return -1;
       return minans;
        


        


        
    }
}
