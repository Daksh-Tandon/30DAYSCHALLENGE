class Solution {
    public int getMinDistance(int[] nums, int target, int start) {
        int n=nums.length;
        int minans=Integer.MAX_VALUE;
        for(int i=0;i<n;i++){
            if(nums[i]==target){
                minans=Math.min(minans,Math.abs(i-start));

            }
        }
        return minans;

        
    }
}
