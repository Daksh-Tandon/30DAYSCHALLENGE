class Solution {
    public int maxDistance(int[] arr) {
        int n=arr.length;
        int i=0,j=n-1;
        int maxans=0;
        while(i<n-1){
            if(arr[i]==arr[j]){
                j--;
            }
            else{
                maxans=Math.max(maxans,j-i);
                i++;
                j=n-1;
            }

        }
        return maxans;
        
    }
}
