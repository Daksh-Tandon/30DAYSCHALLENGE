class Solution {
    public int countoccur(int i,int d){
        int c=0;
        while(i!=0){
            int rem=i%10;
            if(rem==d) c++;
            i=i/10;
        }
        return c;
    }
    public int countDigitOccurrences(int[] nums, int digit) {
        int n=nums.length,count=0;
        for(int i=0;i<n;i++){
            count+=countoccur(nums[i],digit);
        }
        return count;
        
    }
}
